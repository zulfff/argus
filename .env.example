# Argus Configuration

# Admin credentials (development only)
ARGUS_ADMIN_USER=admin
ARGUS_ADMIN_PASS=123456

# JWT Secret (min 32 bytes for production)
ARGUS_JWT_SECRET=dev-secret-key-min-32-bytes-long-for-testing-only

# Production mode (set to 1 for production enforcement)
# ARGUS_PRODUCTION=1

# CORS allowed origins (comma-separated, required in production)
# ARGUS_ALLOWED_ORIGINS=https://dashboard.example.com,https://app.example.com

# TLS certificates (required in production)
# ARGUS_TLS_CERT=/path/to/cert.pem
# ARGUS_TLS_KEY=/path/to/key.pem

# Database (optional, uses in-memory if not set)
# DATABASE_URL=postgresql://user:pass@localhost/argus

# NetBox integration (optional)
# NETBOX_URL=https://netbox.example.com
# NETBOX_TOKEN=your-token-here
