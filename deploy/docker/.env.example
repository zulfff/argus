# ─── ARGUS Docker Environment ──────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All variables have auto-generated defaults — you can run with zero config:
#   docker compose up -d

# JWT signing key (>= 32 bytes)
# If unset, a random key is generated each time the container starts
JWT_SECRET=

# Database password (auto-generated if unset)
DB_PASSWORD=

# Initial admin credentials (auto-generated if unset)
ARGUS_ADMIN_USER=
ARGUS_ADMIN_PASS=

# Grafana admin password (default: admin)
GRAFANA_PASSWORD=

# Log level (default: argus=info)
RUST_LOG=