# ─── ARGUS Docker Environment ──────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required variables (must be set, no fallback):
#   docker compose up -d

# Database password (required)
DB_PASSWORD=change-me-to-a-strong-password

# JWT signing key (>= 32 bytes, required)
JWT_SECRET=change-me-to-a-key-at-least-32-bytes-long

# Initial admin credentials (required)
ARGUS_ADMIN_USER=admin
ARGUS_ADMIN_PASS=change-me-to-a-strong-password

# Grafana admin password (required)
GRAFANA_PASSWORD=change-me-to-a-strong-password

# Log level (default: argus=info)
RUST_LOG=argus=info
